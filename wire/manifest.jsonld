    "r1": "reserved"
  },
  "tier": "Tier-B",
  "scope": {
    "phase": "R0 — ontology + 6 lexicons + 5 cells (ALL coded state machines: intake_triage / evidence_preservation / police_report / platform_abuse / account_recovery; all .solve() RuntimeError at R0) + triage engine (src/tasuke/methods/triage.cljc — scam-kind classifier + severity + free-window routing + first-response checklist + deadline notes; the G1/G4/G7 anchor) + document generator (src/tasuke/methods/report_gen.cljc — member-authored 被害届/被害状況報告書/証拠目録/被害額算定書/銀行組戻し依頼/プラットフォーム依頼/アカウント復旧手順, the G2/G3 anchor) + evidence engine (src/tasuke/methods/evidence.cljc — chain-of-custody sha256 + PII-by-reference, the G6 anchor) + end-to-end membrane (src/tasuke/methods/analyze.cljc — intake→triage→generate→assert-free over the :representative seed; every case journey costs ¥0) + :representative seed (5 victim cases + 9 FREE public windows) + one-command runner. Registered in INFRA_ACTORS → did:web:etzhayyim.com:actor:tasuke. Design + offline generation only; NO live filing / sending / submission.",
    "scopeBoundary": "Free, member-authored, member-submitted cybercrime-victim recovery support (relief documents + free public windows), design-only",
    "exclusions": [
      "any fee / charge / subscription — cash≡0, unrepresentable (N4, G1)",
      "代理作成 / 代理提出 / 代理送付 — the member authors + signs + submits (N1, G2; 行政書士法/弁護士法 独占業務不踏)",
      "police-authored official documents — generated filings are the victim's own (N2, G3; 公文書偽造を排除)",
      "adjudication of fraud / crime — a scam KIND is a routing label, not a verdict (N3, G4; danjo/chigiri boundary)",
      "paid-counsel referral — only FREE public windows (G5; 弁護士へつながない)",
      "plaintext PII storage — evidence is encrypted-by-reference (G6)",
      "server-signed submission / platform-held key (N6, G7/no-server-key)",
      "self-help debt collection / 取立 / 自力救済 (N5)",
      "third-party surveillance — the victim's evidence is their own, encrypted (N7)",
      "live filing / sending / submission (G9 — Council Lv6+ + operator)"
    ]
  },
  "cells": [
    { "name": "intake_triage", "module": "tasuke.cells.intake_triage", "murakumoNode": "reuben", "phase": "consent-gated, free, no-server-key victim intake → scam-KIND + severity + free windows + first-response checklist (G1/G4/G7)", "status": "coded-state-machine", "emitsLexicon": "com.etzhayyim.tasuke.victimIntake", "gates": ["G1", "G4", "G7"] },
    { "name": "evidence_preservation", "module": "tasuke.cells.evidence_preservation", "murakumoNode": "simeon", "phase": "encrypted-by-reference, chain-of-custody-hashed evidence index (G6)", "status": "coded-state-machine", "emitsLexicon": "com.etzhayyim.tasuke.evidenceItem", "gates": ["G6"] },
    { "name": "police_report", "module": "tasuke.cells.police_report", "murakumoNode": "levi", "phase": "member-authored 被害届/被害状況報告書/証拠目録/被害額算定書 generation (G1/G2/G3)", "status": "coded-state-machine", "emitsLexicon": "com.etzhayyim.tasuke.policeReportDraft", "gates": ["G1", "G2", "G3"] },
    { "name": "platform_abuse", "module": "tasuke.cells.platform_abuse", "murakumoNode": "judah", "phase": "member-authored bank-freeze (振り込め詐欺救済法) + platform freeze/recovery/disclosure requests (G1/G2/G3)", "status": "coded-state-machine", "emitsLexicon": "com.etzhayyim.tasuke.platformRequest", "gates": ["G1", "G2", "G3"] },
    { "name": "account_recovery", "module": "tasuke.cells.account_recovery", "murakumoNode": "zebulun", "phase": "self-help account-recovery procedure (G2 :self-submit — 助 never logs in as the member)", "status": "coded-state-machine", "emitsLexicon": "com.etzhayyim.tasuke.recoveryPlan", "gates": ["G2", "G7"] }
  ],
  "lexiconNamespaces": [
    { "id": "com.etzhayyim.tasuke.victimIntake", "status": "implemented", "emittedBy": ["intake_triage"] },
    { "id": "com.etzhayyim.tasuke.evidenceItem", "status": "implemented", "emittedBy": ["evidence_preservation"] },
    { "id": "com.etzhayyim.tasuke.policeReportDraft", "status": "implemented", "emittedBy": ["police_report"] },
    { "id": "com.etzhayyim.tasuke.platformRequest", "status": "implemented", "emittedBy": ["platform_abuse"] },
    { "id": "com.etzhayyim.tasuke.recoveryPlan", "status": "implemented", "emittedBy": ["account_recovery"] },
    { "id": "com.etzhayyim.tasuke.supportCase", "status": "implemented", "emittedBy": ["intake_triage (aggregate case folder)"] }
  ],
  "constitutionalGates": {
    "description": "10 immutable gates per ADR-2606060900. G1 (全て無料), G2 (本人作成・本人提出), and G3 (警察authored不可) are the structural anchors; each lives in three places (schema :db/allowed + lexicon :const/:enum + Python ValueError).",
    "gates": {
      "G1": "全て無料 / cash≡0 — :support/cost-jpy :db/allowed [0]; supportCostJpy const 0; SUPPORT_COST_JPY = 0. A fee / charge / subscription is UNREPRESENTABLE. Every case journey costs the victim ¥0.",
      "G2": "本人作成・本人提出 — :support/role :db/allowed only {:guide :draft-assist :self-submit}; :represent / :proxy-submit / :agent-file UNREPRESENTABLE; every generated doc carries needsMemberSignature const true. 助 drafts; the member authors, signs, and submits (行政書士法/弁護士法 独占業務不踏).",
      "G3": "警察authored不可 — :doc/authored-by :db/allowed [:member]; authoredBy const 'member'; report_gen hard-wires :member. :police / :official / :server UNREPRESENTABLE — a generated filing is the VICTIM's own 申告書類, never a police-authored 公文書 (公文書偽造を構造的に排除).",
      "G4": "Non-adjudicating — a scam KIND classifies for routing; it is NOT a finding that a crime occurred. No :case/verdict exists; the triage output carries no guilt/crime field (danjo/chigiri boundary).",
      "G5": "No paid counsel — :referral/paid and :support/paid-referral :db/allowed [false]; paidReferral const false. 助 routes only to FREE public windows (#9110 / 188 / NCCC / フィッシング対策協議会 / JPCERT / セーフライン / 銀行 / 振り込め詐欺救済法). 弁護士へつながない.",
      "G6": "PII-by-reference — evidence lives in com.etzhayyim.encrypted.* envelopes; only an envelope-ref + a chain-of-custody sha256 sit in the clear. A plaintext-PII field is unrepresentable (evidence.preserve raises) (ADR-2605181100).",
      "G7": "No-server-key — :case/server-held-key :db/allowed [false]; serverHeldKey const false; the member signs every submission. The platform never signs (ADR-2605231525).",
      "G8": "Murakumo-only inference — any LLM refinement of classification/wording runs on the Murakumo fleet (LiteLLM 127.0.0.1:4000), never a commercial GPU (ADR-2605215000).",
      "G9": "Outward-gated — live filing / sending / submission = Council Lv6+ + operator; :doc/published const false at R0; .solve() raises on every cell.",
      "G10": "Sourcing-honesty — the procedure/window registry is :representative; 法定期限 / 窓口 / 根拠法令 must be verified against the primary source before any live use."
    }
  },
  "nonGoals": {
    "description": "7 explicitly excluded scopes",
    "goals": {
      "N1": "NOT a 代理人 — 助 never authors-as, submits-for, or sends-for the member (G2). The member is always the author and the principal (行政書士法/弁護士法 独占業務不踏).",
      "N2": "NOT a generator of official police documents — it produces the victim's own 申告書類 (G3); a police-authored 公文書 is unrepresentable.",
      "N3": "NOT an adjudicator — it does not decide that fraud or a crime occurred (G4). That is the police, the courts, and (for records) danjo/chigiri.",
      "N4": "NOT a paid service — everything is free (G1); and it never routes to paid counsel (G5).",
      "N5": "NOT debt collection / 取立 / 自力救済 — fund recovery is pursued only through lawful free channels (the bank under 振り込め詐欺救済法, the police).",
      "N6": "NO server-signed submission / no platform-held key (G7/no-server-key).",
      "N7": "NOT surveillance — the victim's evidence is the victim's own, encrypted; 助 never builds a third-party profile (G6)."
    }
  },
  "roadmap": [
    { "phase": "R0", "date": "2026-06-05", "scope": "This ADR. Ontology + 6 lexicons + 5 cells + triage engine + document generator + evidence engine + end-to-end membrane + :representative seed (5 cases + 9 free windows). Registered in INFRA_ACTORS. Design + offline generation only; NO live filing/sending.", "gate": "ADR-2606060900 (PROPOSED)" },
    { "phase": "R1", "date": "post-Council", "scope": "Live-but-gated case intake over the consenting member's own evidence; Murakumo-only LLM refinement of classification + Japanese wording; the procedure/window registry promoted :representative→:authoritative against primary sources (ooyake/toritsugi surfaceable); a 'bring this to the police' export. Still free, still member-signed, still no 代理.", "gate": "Future ADR + Council Lv6+ + operator (G9)" },
    { "phase": "R2", "date": "post-R1", "scope": "Standing free victim-support service surfaced via toritsugi (government-procedure concierge) + kurashimori (consumer) + tadori (on-chain trace for crypto cases) + kokoro (psychosocial referral); multi-jurisdiction window registry; live bank/platform submission with member signature (still never 代理).", "gate": "Future ADR + Council Lv6+ + operator" }
  ],
